<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@color/surface_panel"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/teamNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="17sp"
        android:textStyle="bold"
        tools:text="Team 1" />

    <TextView
        android:id="@+id/teamMetaText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        tools:text="Balanced | Overall average | 6 members" />

    <TextView
        android:id="@+id/teamMembersText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        tools:text="Maria Popescu\nAndrei Stan\nIoana Dima" />
</LinearLayout>
