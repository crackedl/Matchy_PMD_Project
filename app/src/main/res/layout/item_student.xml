<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@color/surface_panel"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/studentNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="Alex Ionescu" />

    <TextView
        android:id="@+id/studentEmailText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        tools:text="alex.ionescu@example.com" />

    <TextView
        android:id="@+id/studentSkillSummaryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        tools:text="Programming 5 | Math 4 | Collaboration 5" />
</LinearLayout>
